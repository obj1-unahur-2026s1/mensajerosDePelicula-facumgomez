import destinos.*
import paquete.*
import vehiculos.*
import mensajeros.*
describe "Test 1ra parte" {
  test "Roberto puede llevar un paquete que esta pago en un camion con acoplado" {
    roberto.cambiarVehiculo(camion)
    paquete.serPagado()
    assert.that(roberto.puedeLlevarPaquete(puenteBrooklyn))
  }
  test "Neo con credito no puede llevar paquete que no esta pago a la Matrix" {
    assert.notThat(neo.puedeLlevarPaquete(matrix))
  }
}